---
import Footer from "@/components/marketing/Footer.astro";
import MarketingHeader from "@/components/marketing/MarketingHeader.astro";
import SheetPreview from "@/components/marketing/SheetPreview.astro";
import Layout from "@/layouts/Layout.astro";
import { env } from "@/env";
import { templatePath } from "@/marketing/seo";
import { templates } from "@/marketing/templates";

const title = "Free order form templates — Excel & Google Sheets";
const niches = templates.map((template) => template.niche);
const nicheList =
  niches.length > 1
    ? `${niches.slice(0, -1).join(", ")}, and ${niches.at(-1) ?? ""}`
    : (niches[0] ?? "");
const description = `Working order-sheet templates for ${nicheList}. Download free or turn one into a live order portal.`;

const itemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: templates.map((template, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: `${template.niche} order form template`,
    url: new URL(templatePath(template), env.APP_URL).toString(),
  })),
};
---

<Layout title={title} description={description} jsonLd={[itemList]}>
  <MarketingHeader />
  <main class="mx-auto max-w-5xl px-6 py-16">
    <div class="max-w-2xl">
      <h1 class="text-4xl font-bold tracking-tight">Free order form templates</h1>
      <p class="text-muted-foreground mt-4 text-lg">
        Real, working order sheets — products, prices, and formulas already set up. Use one in
        Excel or Google Sheets, or turn it into a live order portal your buyers order from.
      </p>
    </div>

    <div class="mt-12 grid gap-8 md:grid-cols-2">
      {
        templates.map((template) => (
          <article class="flex flex-col rounded-xl border p-6">
            <div class="flex items-center justify-between">
              <span class="bg-muted text-muted-foreground rounded-full px-3 py-1 text-xs font-medium">
                {template.niche}
              </span>
            </div>
            <h2 class="mt-4 text-xl font-semibold">
              <a href={templatePath(template)} class="hover:underline underline-offset-4">
                {template.cardTitle}
              </a>
            </h2>
            <p class="text-muted-foreground mt-2 text-sm">{template.cardSummary}</p>
            <div class="mt-4">
              <SheetPreview spec={template} limit={3} />
            </div>
            <div class="mt-6 flex items-center gap-4 text-sm">
              <a
                href={templatePath(template)}
                class="text-primary font-medium underline underline-offset-4"
              >
                View template
              </a>
              <a
                href={`/templates/${template.slug}.xlsx`}
                class="text-muted-foreground hover:text-foreground"
              >
                Download .xlsx
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </main>
  <Footer />
</Layout>
