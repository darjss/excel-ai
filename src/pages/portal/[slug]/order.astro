---
import { OrderForm } from "@/components/portal/OrderForm";
import PortalLayout from "@/layouts/PortalLayout.astro";
import { loadPortalPage } from "@/server/portal/page";

export const prerender = false;

const data = await loadPortalPage(Astro.request, Astro.url);
if (!data) return new Response("Portal not found", { status: 404 });

const { config, basePath, slug } = data;
const title = `Order — ${config.business.name}`;
const description = `Place an order with ${config.business.name}.`;
---

<PortalLayout config={config} basePath={basePath} title={title} description={description}>
  <OrderForm client:load config={config} slug={slug} />
</PortalLayout>
