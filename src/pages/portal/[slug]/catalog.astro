---
import { Catalog } from "@/components/portal/Catalog";
import PortalLayout from "@/layouts/PortalLayout.astro";
import { loadPortalPage } from "@/server/portal/page";

export const prerender = false;

const data = await loadPortalPage(Astro.request, Astro.url);
if (!data) return new Response("Portal not found", { status: 404 });

const { config, basePath } = data;
const title = `Catalog — ${config.business.name}`;
const description = `Browse products and prices from ${config.business.name}.`;
---

<PortalLayout config={config} basePath={basePath} title={title} description={description}>
  <Catalog client:load config={config} />
</PortalLayout>
