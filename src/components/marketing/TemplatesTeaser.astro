---
import { templatePath } from "@/marketing/seo";
import { templates } from "@/marketing/templates";

const featured = templates.slice(0, 6);
---

<section class="bg-muted/40 py-20">
  <div class="mx-auto max-w-5xl px-6">
    <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-bold tracking-tight">Start from a working order sheet</h2>
        <p class="text-muted-foreground mt-4">
          Free, genuinely usable templates for the trades that live in spreadsheets. Download one,
          or turn it into a live order portal in a click.
        </p>
      </div>
      <a href="/templates" class="text-primary shrink-0 font-medium underline underline-offset-4">
        Browse all templates
      </a>
    </div>
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        featured.map((template) => (
          <a
            href={templatePath(template)}
            class="hover:border-primary rounded-lg border bg-card p-5 transition-colors"
          >
            <span class="text-muted-foreground text-xs font-medium">{template.niche}</span>
            <p class="mt-2 font-semibold">{template.cardTitle}</p>
            <p class="text-muted-foreground mt-1 text-sm">{template.cardSummary}</p>
          </a>
        ))
      }
    </div>
  </div>
</section>
