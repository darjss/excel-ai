---
import { pricingTiers } from "@/marketing/pricing";
---

<section id="pricing" class="mx-auto max-w-5xl px-6 py-20">
  <h2 class="text-center text-3xl font-bold tracking-tight">Flat pricing, no commission</h2>
  <p class="text-muted-foreground mx-auto mt-4 max-w-2xl text-center">
    Unlimited buyers, unlimited orders. A good month never raises your bill.
  </p>
  <div class="mx-auto mt-12 grid max-w-3xl gap-8 sm:grid-cols-2">
    {
      pricingTiers.map((tier) => (
        <div class:list={["rounded-lg border p-6", tier.highlighted && "border-primary"]}>
          <h3 class="font-semibold">{tier.name}</h3>
          <p class="mt-2 text-3xl font-bold">
            ${tier.priceMonthly}
            <span class="text-muted-foreground text-sm font-normal">/mo</span>
          </p>
          <p class="text-muted-foreground mt-2 text-sm">{tier.tagline}</p>
        </div>
      ))
    }
  </div>
  <p class="mt-8 text-center">
    <a href="/pricing" class="text-primary underline underline-offset-4">See full pricing</a>
  </p>
</section>
