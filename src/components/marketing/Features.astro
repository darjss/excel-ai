---
const features = [
  {
    title: "Your sheet stays the source",
    body: "Edit products and prices where you always have. Import picks up changes; you never rebuild your catalog in someone else's editor.",
  },
  {
    title: "Totals from your own rules",
    body: "Line totals, tax, minimums, and tier pricing come from the formulas already in your sheet — buyers see the number you expect.",
  },
  {
    title: "Orders back in your sheet",
    body: "Every order lands as a row on a platform-owned Orders Tab and in your dashboard, so nothing gets lost in a DM.",
  },
  {
    title: "No buyer accounts",
    body: "Buyers order from a named link in a minute on their phone. No signup, no marketplace between you and them.",
  },
];
---

<section id="features" class="mx-auto max-w-5xl px-6 py-20">
  <h2 class="text-center text-3xl font-bold tracking-tight">Built around your spreadsheet</h2>
  <div class="mt-12 grid gap-8 sm:grid-cols-2">
    {
      features.map((feature) => (
        <div class="rounded-lg border p-6">
          <h3 class="font-semibold">{feature.title}</h3>
          <p class="text-muted-foreground mt-2 text-sm">{feature.body}</p>
        </div>
      ))
    }
  </div>
</section>
